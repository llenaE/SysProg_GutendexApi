## Base Visual Studio / .NET Core gitignore

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Re]leasePublic/
x64/
x86/
[Aa]rm/
[Aa]rm64/
bbin/
bin/
obj/

# Visual Studio cache and settings
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates

# VS Code settings and workspace
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# Rider / JetBrains IDEs
.idea/
*.sln.iml

# OS generated files
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# .NET Core / ASP.NET Core secrets and local runtime files
project.lock.json
project.fragment.lock.json
artifacts/
out/
stylecop.json
appsettings.Development.json
logs/
*.log

# ML.NET auto-generated and temporary training artifacts
# (Dopuštamo čuvanje finalnog .zip modela ako želiš, ali ignorišemo privremene logove)
*.mlnet